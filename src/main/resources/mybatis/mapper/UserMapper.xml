<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.hsms.mapper.ServiceworkerMapper">

    <!-- 动态查询列表 -->
    <select id="list" parameterType="map" resultType="com.example.hsms.entity.Service_Worker">
        SELECT * FROM service_worker
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
        </where>
        <!-- 分页参数需在 Java 代码中处理 -->
        <if test="start != null and pageSize != null">
            LIMIT #{start}, #{pageSize}
        </if>
    </select>

    <!-- 查询总数 -->
    <select id="getTotal" parameterType="map" resultType="java.lang.Long">
        SELECT COUNT(*) FROM service_worker
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>

        </where>
    </select>
</mapper>